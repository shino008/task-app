{
  "name": "flowtasks-app",
  "version": "1.0.0",
  "description": "FlowTasks Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build": "electron-builder --mac --win"
  },
  "author": "FlowTasks",
  "license": "ISC",
  "devDependencies": {
    "electron": "^29.1.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.flowtasks.app",
    "productName": "FlowTasks",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg"],
      "icon": "icon-512.png"
    },
    "win": {
      "target": ["nsis"],
      "icon": "icon-512.png"
    }
  }
}
