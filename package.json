{
  "name": "flowtasks",
  "version": "1.0.0",
  "description": "Creator Task Manager",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.creator.flowtasks",
    "productName": "FlowTasks",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon512.png"
    },
    "win": {
      "target": "nsis",
      "icon": "icon512.png"
    }
  },
  "keywords": [
    "taskmanager",
    "pwa",
    "electron"
  ],
  "author": "Yotaa",
  "license": "MIT",
  "devDependencies": {
    "electron": "^29.1.5",
    "electron-builder": "^24.13.3"
  }
}
